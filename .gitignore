tools/.venv/
.obsidian/
*.pyc
__pycache__/
wiki/.scan-log
wiki/.fileback-log
wiki/.compile-progress.json
.DS_Store

# Raw source material (copyrighted / personal — keep folder structure via .gitkeep)
raw/articles/*
raw/papers/*
raw/repos/*
raw/images/*
!raw/articles/.gitkeep
!raw/papers/.gitkeep
!raw/repos/.gitkeep
!raw/images/.gitkeep

# Personal wiki content (keep folder structure via .gitkeep)
# Example files are explicitly unignored below
wiki/summaries/*
wiki/concepts/*
wiki/topics/*
!wiki/summaries/.gitkeep
!wiki/concepts/.gitkeep
!wiki/topics/.gitkeep

# Auto-generated index files — personal data, recreated by build-index.py on first run
wiki/index.md
wiki/_brief.md

# Personal domain MOCs (keep the template/about file and example)
wiki/domains/*.md
!wiki/domains/_about-domains.md

# Example files — included to demonstrate wiki format
!wiki/concepts/transformer-architecture.md
!wiki/summaries/attention-is-all-you-need.md

# Personal outputs (keep folder structure and templates)
outputs/reports/*
outputs/notes/*
outputs/charts/*
outputs/html/*
!outputs/reports/.gitkeep
!outputs/notes/.gitkeep
!outputs/charts/.gitkeep
!outputs/html/.gitkeep

# Environment variables (API keys, secrets)
.env
.env.*
*.env

# Claude Code — share hooks (settings.json), ignore personal data (memory, sessions)
.claude/*
!.claude/settings.json

# Local agent overrides
.local-rules.md

# Local-only tools (not ready for public release)
tools/test.sh

# Local evaluation data (baselines, corpus, ground-truth — personal, not for public release)
eval/

# Query log — personal search history (auto-generated by search.sh)
wiki/.query-log.jsonl

# last30days plugin scripts — proprietary marketplace plugin, not for redistribution
# Install plugin then: cp -r ~/.claude/plugins/cache/last30days-skill/last30days/*/scripts skills/last30days/scripts
skills/last30days/scripts/
